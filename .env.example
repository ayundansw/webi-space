APP_NAME=WEBI-SPACE

# WAJIB untuk production: APP_ENV=production dan APP_DEBUG=false.
# APP_DEBUG=true menampilkan stack trace lengkap ke publik kalau terjadi error —
# jangan pernah aktif di server production (docs/DEPLOYMENT_CHECKLIST.md).
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: WEBI-SPACE selalu memakai MySQL (lihat docs/tech-stack.md), tidak
# pernah sqlite — isi kelima variabel di bawah sesuai kredensial MySQL server.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WEBI (modul AI companion, docs/spesifikasi-webi.md). Pakai API key dari
# project Google Cloud yang DIDEDIKASIKAN khusus WEBI-SPACE (bukan project yang
# dipakai bareng aplikasi lain) — kuota free tier Gemini per-project, bukan
# per-API-key (lihat CLAUDE.md "Known gaps / backlog dari 2.5").
GEMINI_API_KEY=
# Model keluarga Gemini 3.x yang sudah diuji dan dituning untuk aplikasi ini.
GEMINI_MODEL=gemini-3.5-flash
# Valid: minimal, low, medium, high (khusus keluarga model Gemini 3.x — field
# ini otomatis di-skip kalau GEMINI_MODEL diganti ke seri 2.5). "minimal"
# adalah keputusan final (2026-07-04): trade-off kecepatan vs kedalaman jawaban
# untuk kasus chat companion real-time, lihat CLAUDE.md untuk detail pengujian.
GEMINI_THINKING_LEVEL=minimal
